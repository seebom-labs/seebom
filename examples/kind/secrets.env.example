# ─── Secrets ──────────────────────────────────────────────────────────────────
# Copy this file to local/secrets.env and fill in your values.
#
#   cp examples/kind/secrets.env.example local/secrets.env
#
# ⚠️  NEVER commit local/secrets.env — it is in .gitignore.
# ──────────────────────────────────────────────────────────────────────────────

# ClickHouse password (pick any password for local dev)
CLICKHOUSE_PASSWORD=changeme

# GitHub Personal Access Token (optional, for license resolution)
# Without this: 60 requests/hour. With this: 5000 requests/hour.
# Create at: https://github.com/settings/tokens → Fine-grained → Public repos (read-only)
GITHUB_TOKEN=

# S3 credentials (optional, for S3 bucket ingestion)
# Leave empty for public buckets. These are shared across all configured S3 buckets.
# Per-bucket credentials can be set in the S3_BUCKETS JSON (see values-kind.yaml).
S3_ACCESS_KEY=
S3_SECRET_KEY=

