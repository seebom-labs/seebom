# ============================================================
# SeeBOM – Local Configuration
# ============================================================
# Copy this file to .env and adjust to your setup:
#   cp .env.example .env

# ── SBOM Source ───────────────────────────────────────────────
# Path to your SBOM files. Can be an external repo checkout.
# Default: ./sboms (bundled examples)
SBOM_SOURCE_DIR=./sboms

# ── Ingestion tuning ──────────────────────────────────────────
# Max SBOMs to enqueue per watcher run (0 = all).
# Use 50–200 for quick local dev, 0 for full ingestion.
SBOM_LIMIT=200

# ── Worker tuning ─────────────────────────────────────────────
# Number of parallel parsing worker containers.
WORKER_REPLICAS=2

# Jobs claimed per polling cycle per worker.
WORKER_BATCH_SIZE=50

# Skip OSV vulnerability API calls for fast ingestion (licenses only).
# Set to "true" for initial bulk load, then re-run with "false".
SKIP_OSV=true

# ── GitHub License Resolution ─────────────────────────────────
# Resolves unknown/NOASSERTION licenses by querying GitHub API.
# Without token: 60 requests/hour. With token: 5000 requests/hour.
# Create at: https://github.com/settings/tokens (no scopes needed for public repos)
SKIP_GITHUB_RESOLVE=false
GITHUB_TOKEN=

